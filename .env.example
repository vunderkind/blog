# Local dev doesn't need most of these — docker-compose hardcodes
# http://localhost:2368 and skips bulk email.
#
# On Fly, these values become *secrets* (not env vars) via:
#   flyctl secrets set MAIL_USER=... MAIL_PASS=... etc.
# Copy this file to .env only if you also want to test newsletters locally.

# ── Transactional mail (password resets, staff invites) ─────────────────
MAIL_SERVICE=Mailgun
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=postmaster@mg.example.com
MAIL_PASS=replace-me
MAIL_FROM="Blog <hello@example.com>"

# ── Bulk email / newsletter delivery ────────────────────────────────────
MAILGUN_API_KEY=key-replace-me
MAILGUN_DOMAIN=mg.example.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# Stripe is configured in Ghost Admin → Settings → Membership (not here).
