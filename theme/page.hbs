{{!< default}}

{{#post}}
<article class="post">
  {{#match @page.show_title_and_feature_image "!=" false}}
    {{#if title}}<h1>{{title}}</h1>{{/if}}
    {{#if custom_excerpt}}<p class="subtitle">{{custom_excerpt}}</p>{{/if}}
    {{#if feature_image}}
    <figure class="kg-card kg-image-card kg-width-wide">
      <img src="{{img_url feature_image size="xl"}}" alt="{{feature_image_alt}}" />
      {{#if feature_image_caption}}<figcaption>{{{feature_image_caption}}}</figcaption>{{/if}}
    </figure>
    {{/if}}
  {{/match}}
  <section class="content">{{content}}</section>
</article>
{{/post}}
